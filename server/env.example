# Server Configuration
PORT=3001
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/psm
# For MongoDB Atlas (Cloud):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/psm?retryWrites=true&w=majority

# JWT Secret (Generate a strong random string for production)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d

# Admin Credentials (Hardcoded - Only one admin account)
ADMIN_EMAIL=admin@parking.com
ADMIN_PASSWORD=admin123

# SMTP (for booking confirmation emails) - Optional
# If not configured, booking emails will be skipped (no error)
# Common SMTP providers:
#   Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_SECURE=false
#   Outlook: SMTP_HOST=smtp-mail.outlook.com, SMTP_PORT=587, SMTP_SECURE=false
#   SendGrid: SMTP_HOST=smtp.sendgrid.net, SMTP_PORT=587, SMTP_SECURE=false
#   Mailgun: SMTP_HOST=smtp.mailgun.org, SMTP_PORT=587, SMTP_SECURE=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
MAIL_FROM="Parking Management" <no-reply@yourdomain.com>

